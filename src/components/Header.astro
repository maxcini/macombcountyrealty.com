---
// src/components/Header.astro
---

<header class="site-header">
    <div class="header-container">
        
        <div class="brand-container">
            <a class="brand" href="https://www.macombcountyrealty.com/">
                <img class="brand-logo" src="/images/logo.png" width="220" height="67" alt="Macomb County Realty">
                <div class="brand-text sr-only">
                    <b class="brand-name">Macomb County Realty</b>
                    <span class="tagline">Need To Sell Your House Fast? We Buy Houses!</span>
                </div>
            </a>
        </div>

        <div class="nav-and-actions">
            <nav class="main-navigation">
                <button id="mobile-menu-btn" class="menu-toggle" type="button" aria-expanded="false">
                    <span class="hamburger-box">
                        <span class="hamburger-inner"></span>
                    </span>
                    <span class="sr-only">Toggle Navigation Menu</span>
                </button>
                <ul id="main-nav" class="nav-menu">
                    <li><a href="#how-it-works">How It Works</a></li>
                    <li><a href="#about">About Us</a></li>
                    <li><a href="#faq">FAQ</a></li>
                </ul>
            </nav>

            <div class="header-actions">
                <a class="contact-phone" href="tel:+15864157355" aria-label="Call or Text Us">
                    <div class="contact-phone-desktop">
                        <span class="contact-phone-text">Call Or Text!</span>
                        <span class="contact-phone-number">
                            <b>(586) 415–7355</b>
                        </span>
                    </div>
                    <div class="contact-phone-mobile">
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#e5243b" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
                    </div>
                </a>
            </div>
        </div>

    </div>
</header>