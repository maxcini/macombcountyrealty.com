---
// src/pages/index.astro
import Layout from "../layouts/Layout.astro";
import { michiganCities } from "../data/michiganCities.js";
---

<Layout
    title="Sell My House Fast Macomb County Michigan"
    description="Looking to sell your house fast in Macomb County? Macomb County Realty buys houses cash, 100% as-is, with zero fees or commissions. Call Max for your cash offer today!"
>
    <main>
        <section id="top" class="hero-section">
            <div class="hero-container">
                <div class="hero-image-wrapper">
                    <img
                        src="/images/hero-cutout-ps.webp"
                        alt="Max Mancini Jr and Sr, father and son owners of Macomb County Realty"
                        class="hero-person-img"
                    />
                </div>

                <div class="hero-card">
                    <h1 class="hero-card-title">
                        Sell My House Fast in Metro Detroit, MI
                    </h1>

                    <ul class="hero-bullets">
                        <li class="bullet-item">
                            <span class="checkmark">✓</span> All Cash Offer in 24
                            Hours
                        </li>
                        <li class="bullet-item">
                            <span class="checkmark">✓</span> Explore Market Listing
                            Option
                        </li>
                        <li class="bullet-item">
                            <span class="checkmark">✓</span> 100% Free & No Obligation
                        </li>
                    </ul>

                    <form id="lead-form" class="hero-inline-form">
                        <input
                            type="hidden"
                            name="access_key"
                            value="3a7d522a-4543-4f76-93a8-e1478c789775"
                        />

                        <input
                            type="checkbox"
                            name="botcheck"
                            class="hidden"
                            style="display: none;"
                        />

                        <input
                            type="hidden"
                            name="Property Address"
                            id="hidden-address-field"
                        />

                        <input
                            type="hidden"
                            name="from_name"
                            value="Macomb County Realty Leads"
                        />
                        <input
                            type="hidden"
                            name="subject"
                            value="🏡 New Lead From Landing Page!"
                        />

                        <div
                            class="inline-form-group"
                            id="step-1"
                            style="position: relative;"
                        >
                            <div class="address-field-wrapper">
                                <label class="sr-only" for="address-input"
                                    >Property Address</label
                                >
                                <input
                                    type="text"
                                    id="address-input"
                                    placeholder="Enter your property address..."
                                    autocomplete="off"
                                    class="form-input-secondary form-input-address"
                                />

                                <input
                                    type="text"
                                    id="validation-anchor"
                                    tabindex="-1"
                                    style="position: absolute; left: 15%; top: 50%; width: 1px; height: 1px; opacity: 0; pointer-events: none; border: none; padding: 0;"
                                />

                                <ul
                                    id="address-predictions"
                                    class="address-predictions-list"
                                    role="listbox"
                                >
                                </ul>
                            </div>

                            <button
                                type="button"
                                id="next-btn"
                                class="btn-next"
                            >
                                Get My Options <span class="arrow">➔</span>
                            </button>
                        </div>

                        <div class="step-2-wrapper hidden" id="step-2">
                            <div class="step-2-inputs">
                                <label class="sr-only" for="name">Name</label>
                                <input
                                    type="text"
                                    id="name"
                                    name="Name"
                                    placeholder="Name*"
                                    required
                                    class="form-input-secondary"
                                />

                                <label class="sr-only" for="email"
                                    >Email Address</label
                                >
                                <input
                                    type="email"
                                    id="email"
                                    name="Email Address"
                                    placeholder="Email*"
                                    required
                                    class="form-input-secondary"
                                />

                                <label class="sr-only" for="phone"
                                    >Phone Number</label
                                >
                                <input
                                    type="tel"
                                    id="phone"
                                    name="Phone Number"
                                    placeholder="Phone Number*"
                                    required
                                    class="form-input-secondary"
                                />

                                <button
                                    type="submit"
                                    id="submit-btn"
                                    class="btn-next"
                                >
                                    Submit Info <span class="arrow">➔</span>
                                </button>
                            </div>
                        </div>

                        <div
                            class="success-message-wrapper hidden"
                            id="form-success"
                        >
                            <div class="success-icon">✓</div>
                            <h3 class="success-title">Submission Received!</h3>
                            <p class="success-text">
                                Thank you. Max will review your property details
                                and contact you shortly with your custom
                                options.
                            </p>
                        </div>
                    </form>

                    <p class="hero-trusted-tagline">
                        PROUDLY SERVING METRO DETROIT HOMEOWNERS SINCE 1994
                    </p>

                    <div class="hero-ratings-container">
                        <div class="rating-badge-item">
                            <span class="rating-score"
                                >📍 Locally Owned & Operated</span
                            >
                        </div>

                        <div class="rating-badge-item">
                            <span class="rating-score"
                                >🔒 100% Secure & Confidential</span
                            >
                        </div>
                    </div>
                </div>
            </div>
        </section>
    </main>

    <section class="trust-bar-section">
        <div class="trust-bar-container">
            <span class="trust-item">✓ 30+ Years Experience</span>
            <span class="trust-item">✓ Local Family Owned</span>
            <span class="trust-item">✓ Licensed MI Broker</span>
            <span class="trust-item">✓ All Cash Offers</span>
            <span class="trust-item">✓ Market Listing Option</span>
        </div>
    </section>

    <section id="how-it-works" class="benefits-section">
        <div class="benefits-container">
            <div class="benefits-header">
                <h2 class="benefits-title">
                    How We Make Selling <span class="premium-underline"
                        >Easy</span
                    >
                </h2>
                <p class="benefits-subtitle">
                    Whether you're looking for a quick cash sale or maximum
                    market value, we'll help you understand your options and
                    choose the path that's right for you.
                </p>
            </div>
            <div class="benefits-grid">
                <div class="benefits-card">
                    <svg
                        xmlns="http://www.w3.org/2000/svg"
                        class="benefits-icon"
                        viewBox="0 0 16 16"
                    >
                        <g fill="none">
                            <path
                                fill="#ffffff"
                                stroke="#2E347A"
                                stroke-width="1.5"
                                d="M1 4.75C1 3.784 1.784 3 2.75 3h10.5c.966 0 1.75.784 1.75 1.75v6.5A1.75 1.75 0 0 1 13.25 13H2.75A1.75 1.75 0 0 1 1 11.25z"
                            ></path>
                            <path
                                fill="#4A6D7C"
                                d="M9.5 6a.5.5 0 0 0 0 1h3a.5.5 0 0 0 0-1zm0 3a.5.5 0 0 0 0 1h3a.5.5 0 0 0 0-1z"
                            ></path>
                            <path
                                fill="#4A6D7C"
                                d="M3.858 8.392A.86.86 0 0 0 3 9.25a1.67 1.67 0 0 0 1.265 1.62l.053.014c.62.155 1.267.155 1.886 0l.054-.013a1.67 1.67 0 0 0 1.265-1.62a.86.86 0 0 0-.858-.859z"
                            ></path>
                            <path
                                fill="#4A6D7C"
                                d="M5.261 7.714a1.357 1.357 0 1 0 0-2.714a1.357 1.357 0 0 0 0 2.714"
                            ></path>
                        </g>
                    </svg>
                    <h3 class="benefits-card-title">Contact Max Today</h3>
                    <p class="benefits-card-text">
                        Tell us about your property, timeline, and goals. We'll
                        provide a free, confidential, no-obligation consultation
                        to help you understand the best options for your
                        situation.
                    </p>
                    <a href="/contact" class="btn-card-cta">Start Now!</a>
                </div>
                <div class="benefits-card">
                    <svg
                        xmlns="http://www.w3.org/2000/svg"
                        class="benefits-icon"
                        viewBox="0 0 24 24"
                    >
                        <title>Review Your Options</title>
                        <path
                            fill="#4A6D7C"
                            d="M7 14h1.625q.2 0 .388-.075t.337-.225l4.7-4.7q.225-.225.338-.513t.112-.562t-.125-.537t-.325-.488l-.9-.95q-.225-.225-.5-.337t-.575-.113q-.275 0-.562.113T11 5.95l-4.7 4.7q-.15.15-.225.338T6 11.375V13q0 .425.288.713T7 14m6-6.075L12.075 7zM7.5 12.5v-.95l2.525-2.525l.5.45l.45.5L8.45 12.5zm3.025-3.025l.45.5l-.95-.95zm.65 4.525H17q.425 0 .713-.288T18 13t-.288-.712T17 12h-3.825z"
                        ></path>
                        <path
                            fill="#2E347A"
                            d="M6 18l-2.3 2.3q-.475.475-1.088.213T2 19.575V4q0-.825.588-1.412T4 2h16q.825 0 1.413.588T22 4v12q0 .825-.587 1.413T20 18zm-.85-2H20V4H4v13.125zM4 16V4z"
                        ></path>
                    </svg>
                    <h3 class="benefits-card-title">
                        Review Cash Offer/Listing
                    </h3>
                    <p class="benefits-card-text">
                        Compare the highest cash offer with the potential value
                        of listing your home on the open market. We'll walk you
                        through both options so you can make an informed
                        decision with confidence.
                    </p>
                </div>

                <div class="benefits-card">
                    <svg
                        xmlns="http://www.w3.org/2000/svg"
                        class="benefits-icon"
                        viewBox="-1 -1 18 18"
                    >
                        <title>Get Paid On Your Timeline</title>
                        <path
                            fill="#2E347A"
                            stroke="#2E347A"
                            stroke-width="0.6"
                            stroke-linejoin="round"
                            d="M7.293 1.5a1 1 0 0 1 1.414 0L11 3.793V2.5a.5.5 0 0 1 .5-.5h1a.5.5 0 0 1 .5.5v3.293l2.354 2.353a.5.5 0 0 1-.708.708L8 2.207l-5 5V13.5a.5.5 0 0 0 .5.5h4a.5.5 0 0 1 0 1h-4A1.5 1.5 0 0 1 2 13.5V8.207l-.646.647a.5.5 0 1 1-.708-.708z"
                        ></path>
                        <path
                            fill="#4A6D7C"
                            d="M12.5 16a3.5 3.5 0 1 0 0-7a3.5 3.5 0 0 0 0 7m1.679-4.493l-1.335 2.226a.75.75 0 0 1-1.174.144l-.774-.773a.5.5 0 0 1 .708-.707l.547.547l1.17-1.951a.5.5 0 1 1 .858.514"
                        ></path>
                    </svg>
                    <h3 class="benefits-card-title">
                        Get Paid On Your Timeline
                    </h3>
                    <p class="benefits-card-text">
                        Whether you sell directly to us or list your home on the
                        open market, we'll provide honest guidance, explain your
                        options, and help you close on a timeline that works
                        best for you.
                    </p>
                </div>
            </div>
        </div>
    </section>

    <section class="about-we-buy-section">
        <div class="section-container about-container">
            <div class="about-content">
                <h2>We Buy Houses in Metro Detroit</h2>

                <!-- <p>Need to <a href="/sell-your-house-fast-metro-detroit/"><strong>sell your house fast</strong></a>? Whether your home needs extensive repairs, has been difficult to sell, or you simply want an easier process, Macomb County Realty can help. We serve homeowners throughout the Metro Detroit area, presenting the highest cash offer and closing on your timeline.</p> -->
                <p>
                    Need to sell your house fast? Whether your home needs
                    extensive repairs, has been difficult to sell, or you simply
                    want an easier process, Macomb County Realty can help. We
                    serve homeowners throughout the Metro Detroit area,
                    presenting the highest cash offer and closing on your
                    timeline.
                </p>

                <!-- <p>Because <a href="/sell-your-house/"><strong>we buy houses completely "as-is,"</strong></a> you never have to worry about repairs, cleanup, or costly updates before selling. The Fraser home shown here is a real example of a before-and-after picture of a property we purchased. Whether you're dealing with an inherited property, foreclosure, divorce, or a house that simply needs work, we'll help you explore your options and choose the path that's right for you.</p> -->
                <p>
                    Because we buy houses completely "as-is," you never have to
                    worry about repairs, cleanup, or costly updates before
                    selling. The Fraser home shown here is a real example of a
                    before-and-after picture of a property we purchased. Whether
                    you're dealing with an inherited property, foreclosure,
                    divorce, or a house that simply needs work, we'll help you
                    explore your options and choose the path that's right for
                    you.
                </p>

                <p>
                    Ready to learn what your home is worth? Call Max today at <a
                        href="tel:5864157355"
                        class="cta-phone-link"
                        ><strong>(586) 415–7355</strong></a
                    > for a free, no-obligation consultation and cash offer.
                </p>
            </div>

            <div class="before-after-container">
                <div class="image-wrapper before">
                    <img
                        src="/images/before-img.webp"
                        alt="Metro Detroit House Before Renovations"
                        loading="lazy"
                    />
                    <span class="label">Before</span>
                </div>

                <div class="image-wrapper after">
                    <img
                        src="/images/after-img.webp"
                        alt="Metro Detroit House After Renovations"
                        loading="lazy"
                    />
                    <span class="label">After</span>
                </div>
                <div class="before-after-caption">
                    <strong>Fraser, Michigan</strong><br />
                    <span>Purchased As-Is &bull; Closed in 7 days</span>
                </div>
            </div>
        </div>
    </section>

    <section id="about" class="meet-max-section">
        <div class="section-container meet-max-container">
            <div class="meet-max-image">
                <img
                    src="/images/dad-about.jpg"
                    alt="Headshot of Max Mancini Sr, Macomb County Real Estate Professional"
                    loading="lazy"
                />
            </div>

            <div class="meet-max-content">
                <h2>Meet Max Mancini</h2>
                <p class="meet-subtitle">Michigan Estate Professional</p>

                <img
                    src="/images/dad-about.jpg"
                    class="max-image-mobile"
                    alt="Headshot of Max Mancini Sr, Macomb County Real Estate Professional"
                />

                <p>
                    Hi, I’m Max. For more than 30 years, I've been helping
                    homeowners across Metro Detroit buy, sell, and navigate real
                    estate with confidence. Whether you're looking for a fast
                    cash offer or want to maximize your sale price on the open
                    market, I'm here to help you understand your options and
                    make the decision that's right for you.
                </p>

                <p>
                    Unlike many companies that only offer one solution, I can
                    provide both a cash offer and a traditional listing,
                    providing you with a side-by-side comparison so you can make
                    an informed decision.
                </p>

                <p>
                    I provide honest numbers, straightforward advice, and clear
                    guidance from start to finish.
                </p>

                <ul class="max-options-list">
                    <li>
                        <strong>Highest Cash Offer:</strong> I will give you the highest
                        cash offer. Sell as-is. No Fees. No Commissions. Close on
                        your timeline.
                    </li>
                    <li>
                        <strong>Sell to Open Market:</strong> If it makes more sense,
                        I will put your home on the MLS for the highest price and
                        lowest commission.
                    </li>
                </ul>

                <p>
                    Call Max today so you know exactly where you stand and what
                    your best path forward looks like, without any stress or
                    confusion.
                </p>

                <div class="meet-max-actions">
                    <a href="tel:+15864157355" class="btn-cta"
                        >Call (586) 415–7355</a
                    >
                    <a
                        href="mailto:max@macombcountyrealty.com"
                        class="btn-secondary">Email Max</a
                    >
                </div>
            </div>
        </div>
    </section>

    <section class="why-us-section">
        <div class="section-container">
            <div class="why-us-header">
                <h2>
                    Why Metro Detroit Homeowners<br/>Choose Us
                </h2>
                <p>
                    We believe homeowners deserve honest advice, clear options,
                    and a solution that fits their situation, not a
                    one-size-fits-all sales pitch.
                </p>
            </div>

            <div class="why-us-grid">
                <div class="why-us-card">
                    <h3>Local Family-Owned Business</h3>
                    <p>
                        You’ll work directly with Max from start to finish—no
                        middlemen, no call centers, and no corporate shuffle.
                        Just clear, 1-on-1 guidance through every step of the
                        process from first conversation to closing.
                    </p>
                </div>

                <div class="why-us-card">
                    <h3>More Than One Solution</h3>
                    <p>
                        Most investors only want to buy your house. We can
                        provide a cash offer and also explain what your home may
                        be worth on the open market so you can compare both
                        options before making a decision.
                    </p>
                </div>

                <div class="why-us-card">
                    <h3>Licensed Michigan Broker</h3>
                    <p>
                        As a licensed real estate broker in Michigan, we operate
                        under professional and ethical standards designed to
                        protect homeowners. You stay in full control of every
                        decision with no pressure to move forward.
                    </p>
                </div>

                <div class="why-us-card">
                    <h3>30+ Years of Local Experience</h3>
                    <p>
                        We've spent decades working in Metro Detroit real estate
                        and understand local neighborhoods, buyer demand, and
                        property values. You're getting guidance from someone
                        who knows the market firsthand.
                    </p>
                </div>
            </div>

            <div class="why-us-statement">
                <blockquote>
                    "Our goal is to help you understand both options and choose
                    the path that is best for your situation. When you're ready,
                    we're <a href="tel:5864157355" class="cta-phone-link"
                        ><strong>here to talk.</strong></a
                    >"
                </blockquote>
            </div>
        </div>
    </section>

    <section class="comparison-section">
        <div class="comparison-container">
            <div class="comparison-header">
                <h2 class="comparison-title">
                    Which Option is <span class="premium-underline"
                        >Right For You?</span
                    >
                </h2>
                <p class="comparison-subtitle">
                    Compare a direct cash offer with a traditional market
                    listing to see what makes the most sense for your timeline
                    and goals.
                </p>
            </div>

            <div class="comparison-table-wrapper">
                <table class="comparison-table">
                    <thead>
                        <tr>
                            <th class="feature-col">Feature</th>
                            <th class="cash-col">Our Cash Offer</th>
                            <th class="market-col"
                                >Traditional Market Listing</th
                            >
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td class="feature-col">Time to Close</td>
                            <td class="cash-col"
                                ><strong>As fast as 7 days</strong></td
                            >
                            <td class="market-col">Typically 30 - 60 days</td>
                        </tr>
                        <tr>
                            <td class="feature-col">Repairs & Cleaning</td>
                            <td class="cash-col"
                                ><strong>None. We buy As-Is.</strong></td
                            >
                            <td class="market-col"
                                >Standard market prep & minor touch-ups</td
                            >
                        </tr>
                        <tr>
                            <td class="feature-col">Commissions & Fees</td>
                            <td class="cash-col"
                                ><strong>$0 (We cover closing costs)</strong
                                ></td
                            >
                            <td class="market-col"
                                >Standard realtor commissions apply</td
                            >
                        </tr>
                        <tr>
                            <td class="feature-col">Showings & Open Houses</td>
                            <td class="cash-col"><strong>None</strong></td>
                            <td class="market-col"
                                >Scheduled showings & open houses</td
                            >
                        </tr>
                        <tr>
                            <td class="feature-col">Closing Certainty</td>
                            <td class="cash-col"
                                ><strong>Guaranteed cash close</strong></td
                            >
                            <td class="market-col"
                                >Dependent on buyer financing approval</td
                            >
                        </tr>
                    </tbody>
                </table>
            </div>

            <div class="comparison-cta">
                <p class="comparison-cta-text">
                    Not sure which option is best? We'll help you compare both.
                </p>
                <a href="/contact" class="comparison-cta-btn"
                    >Get My Options <span class="arrow">➔</span></a
                >
            </div>
        </div>
    </section>

    <section class="situations-section">
        <div class="section-container">
            <div class="section-header">
                <h2>Situations We Help With</h2>
                <p>
                    Every homeowner's situation is different. Whether you need
                    to sell quickly, maximize your home's value, or simply
                    understand your options, we're here to help you make the
                    right decision for your circumstances.
                </p>
            </div>

            <div class="situations-grid">
                <div class="situation-card">
                    <h3>Inherited Property</h3>
                    <p>
                        Inherited a house you don't plan to keep? We can help
                        you explore your options and sell on a timeline that
                        works for you.
                    </p>
                </div>

                <div class="situation-card">
                    <h3>Home Needs Repairs</h3>
                    <p>
                        Major repairs, deferred maintenance, or an outdated
                        property? Sell as-is without making costly improvements.
                    </p>
                </div>

                <div class="situation-card">
                    <h3>Behind on Payments</h3>
                    <p>
                        If you're feeling financial pressure, understanding your
                        options early can provide more flexibility and peace of
                        mind.
                    </p>
                </div>

                <div class="situation-card">
                    <h3>Divorce or Life Changes</h3>
                    <p>
                        Major life transitions often require important real
                        estate decisions. We'll provide clear guidance and
                        practical options.
                    </p>
                </div>

                <div class="situation-card">
                    <h3>Expired Listing</h3>
                    <p>
                        If your home didn't sell with another realtor, we will
                        create a marketing plan that will guarantee a successful
                        sale.
                    </p>
                </div>

                <div class="situation-card">
                    <h3>Need to Sell Quickly</h3>
                    <p>
                        Sometimes timing matters. We can discuss fast-sale
                        options and help you understand what is realistic for
                        your property.
                    </p>
                </div>
            </div>

            <div class="situations-footer">
                <p>We can sell your Metro Detroit home for any reason!</p>
                <p>
                    Call or text Max today at <a
                        href="tel:5864157355"
                        class="cta-phone-link"
                        ><strong>(586) 415–7355</strong></a
                    >.
                </p>
            </div>
        </div>
    </section>

    <section id="faq" class="faq-section">
        <div class="faq-container">
            <div class="faq-header">
                <span class="header-pill">Got Questions?</span>
                <h2 class="faq-title">FAQ: Selling Options</h2>
            </div>

            <div class="faq-grid">
                <div class="faq-column cash-path">
                    <div class="faq-path-header">
                        <div class="faq-path-badge cash-badge">
                            Fast &amp; Direct
                        </div>
                        <h3>All-Cash Offer FAQs</h3>
                        <p class="faq-path-desc">
                            Best for speed, certainty, and selling completely
                            "as-is" without listing stress.
                        </p>
                    </div>

                    <div class="faq-items-list">
                        <div class="faq-item">
                            <h4 class="faq-question">
                                Will you make a lowball offer on my home?
                            </h4>
                            <p class="faq-answer">
                                No. Our cash offers are calculated transparently
                                based on recent neighborhood sales data and
                                projected repair costs. While cash offers sit
                                below top market retail value, you eliminate
                                agent commissions, closing fees, staging costs,
                                and months of holding expenses—often netting a
                                similar amount out-of-pocket with zero hassle.
                            </p>
                        </div>

                        <div class="faq-item">
                            <h4 class="faq-question">
                                Are there any hidden fees or extra costs?
                            </h4>
                            <p class="faq-answer">
                                Absolutely none. What we offer is exactly what
                                you walk away with. We cover 100% of the closing
                                costs, and because there are no real estate
                                agents involved, you pay zero commissions,
                                marketing fees, or surprise transactional costs.
                            </p>
                        </div>

                        <div class="faq-item">
                            <h4 class="faq-question">
                                Do I need to clean up or make repairs first?
                            </h4>
                            <p class="faq-answer">
                                Not a single thing. We buy houses in absolute
                                "as-is" condition. You can leave behind unwanted
                                furniture, trash, dirt, or costly structural
                                issues—our team handles everything after the
                                purchase is finalized.
                            </p>
                        </div>
                    </div>
